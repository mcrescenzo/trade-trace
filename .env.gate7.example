# Trade Trace Gate 7 live-adapter provisioning template.
#
# Copy this file to .env.gate7.local, fill in the values, and keep the local
# copy uncommitted. .gitignore intentionally ignores .env and .env.* except
# example templates.
#
# IMPORTANT: do not paste the real RPC URL/key into chat, Beads, release notes,
# committed docs, shell history, or any tracked file.

# Isolated throwaway journal home for Gate 7. Do not use your real journal.
TRADE_TRACE_HOME="$HOME/.trade-trace-gate7-preflight-v002"

# Public Gamma API base URL. No key/auth required; keep as-is unless we discover
# a documented Polymarket API change during the live smoke.
TT_POLYMARKET_GAMMA_BASE_URL="https://gamma-api.polymarket.com"

# Disposable Polygon RPC URL. This is secret-sensitive because provider URLs
# usually embed an API key/project token. Use a dedicated free-tier project that
# can be deleted/rotated immediately after Gate 7.
TT_POLYMARKET_POLYGON_RPC_URL="https://<your-disposable-polygon-rpc-url-with-project-key>"

# Provider label for sanitized evidence only: alchemy, quicknode, infura, ankr,
# polygon-rpc.com, or similar. Do NOT include account IDs or API keys here.
TT_POLYMARKET_RPC_PROVIDER="<provider-name-only>"

# Public Polymarket identifiers for the live smoke.
# Use binary YES/NO markets. The current adapter calls Gamma GET /markets/{id};
# if the public page exposes both a market id and conditionId, prefer the Gamma
# market id here and record the conditionId in the evidence note if different.
TT_POLYMARKET_OPEN_MARKET_ID="<open-active-binary-polymarket-market-id>"
TT_POLYMARKET_RESOLVED_MARKET_ID="<resolved-binary-polymarket-market-id>"

# Safety caps for the live run. Start conservative; Gate 7 only needs bind,
# snapshot.fetch, and outcome.fetch. The later rate-limit bead may use a separate
# owner-approved cap.
TT_POLYMARKET_WALL_CLOCK_CAP_SECONDS="300"
TT_POLYMARKET_CALL_COUNT_CAP="12"

# Local-only provisioning evidence. This should exist for trade-trace-a8ti, but
# should not be committed. Keep it outside the repo to avoid accidental staging.
TT_GATE7_LOCAL_EVIDENCE_PATH="$HOME/.trade-trace-gate7/provisioning-evidence.md"
