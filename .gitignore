
# Beads / Dolt files. Per trade-trace-piav the public release
# repo MUST NOT track .beads/ contents — neither config nor
# metadata nor README. Internal collaborators use bd locally;
# the Dolt sync handles project state outside the repo.
.beads/
.dolt/
*.db
.beads-credential-key

# Audit/review run artifacts. Per trade-trace-piav and trade-trace-jr9b,
# generated audit/review exports (mutation logs, coverage ledgers,
# readback dumps, candidate matrices) are internal artifacts that must
# never enter the public repo; they carry personal email/name
# metadata and local absolute paths by construction.
audits/
docs/audits/
docs/reviews/

# Local agent state
.claude/

# Python package artifacts
__pycache__/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
uv.lock
dist/
build/
venv/
.venv/

