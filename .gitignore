
# Beads / Dolt files. Per trade-trace-piav the public release
# repo MUST NOT track .beads/ contents — neither config nor
# metadata nor README. Internal collaborators use bd locally;
# the Dolt sync handles project state outside the repo.
.beads/
.dolt/
*.db
.beads-credential-key

# Audit/review run artifacts. Per trade-trace-piav and trade-trace-jr9b,
# generated audit/review exports (mutation logs, coverage ledgers,
# readback dumps, candidate matrices) are internal artifacts that must
# never enter the public repo; they carry personal email/name
# metadata and local absolute paths by construction.
audits/
docs/audits/
docs/reviews/

# Local agent state. `.claude/*` / `.opencode/*` (not `dir/`) so tracked
# exceptions below can re-include children: settings.json (session
# hooks), skills/ (repo-local loop skills, per trade-trace-x7w7s), and
# the opencode command/agent adapters (per trade-trace-dhvmi). The
# .opencode plugin workspace (node_modules, package.json, goals/,
# workflows/) stays local via the `*` pattern.
.opencode/*
!.opencode/command/
!.opencode/agent/
!.opencode/skills/
.claude/*
!.claude/settings.json
!.claude/skills/
.codex/
.hermes/
.hermes-bughunt/

# Local environment files / live-test secrets. Keep examples trackable.
.env
.env.*
!.env*.example

# Python package artifacts
__pycache__/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
uv.lock
dist/
build/
venv/
.venv/

# Trade Trace runtime
trade-trace.sqlite
*.sqlite
*.sqlite-wal
*.sqlite-shm
.repo-review/
